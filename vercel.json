{
  "version": 2,
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.6.0"
    },
    "pages/**/*.php": {
      "runtime": "vercel-php@0.6.0"
    },
    "auth/**/*.php": {
      "runtime": "vercel-php@0.6.0"
    },
    "index.php": {
      "runtime": "vercel-php@0.6.0"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}